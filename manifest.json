{
  "manifest_version": 3,
  "name": "CozyTube",
  "version": "1.4.1",
  "description": "CozyTube — open YouTube videos in a new tab on left click so your feed stays in place.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "CozyTube",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["defaults.js", "content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
